{
  "name": "birl",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n worker,app -c auto \"npm:dev:worker\" \"npm:dev:app\"",
    "dev:app": "vite",
    "dev:worker": "wrangler dev --remote --port 8787",
    "cf:dev": "npm run build && sst dev",
    "build": "vite build",
    "deploy": "npm run build && sst deploy",
    "preview": "vite preview",
    "check": "tsc --noEmit -p tsconfig.app.json && tsc -p tsconfig.node.json"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@cloudflare/workers-types": "^4.20260408.1",
    "@rolldown/plugin-babel": "^0.2.2",
    "@tsconfig/svelte": "^5.0.8",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^9.2.1",
    "sst": "^3.18.8",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "wrangler": "^4.42.0"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@hello-pangea/dnd": "^18.0.1",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-form": "^1.28.6",
    "@tanstack/react-query": "^5.96.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2",
    "valibot": "^1.3.1"
  }
}
